<% layout('layouts/boilerplate') %>

<div class="row mt-3">
  <div class="col-8 offset-2">

    <h1>Edit Listing</h1>

    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" 
      novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label">Title</label>
            <input 
              type="text" 
              name="listing[title]"   
              value="<%= listing.title %>" 
              class="form-control" 
              required
            >
             <div class="invalid-feedback">Please provide a title for your listing.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <input 
              type="text" 
              name="listing[description]"   
              value="<%= listing.description %>" 
              class="form-control" 
              required
            >
             <div class="invalid-feedback">Please provide a title for your listing.</div>
    
        </div>

         <div class="mb-3">
          Original Listing Image
    <% if(listing.image && listing.image.url){ %>
  <img src="<%= listing.image.url %>" alt="listing image">
<% } %>
         </div>


        <div class="mb-3">
            <label class="form-label">Upload New Image URL</label>
            <input 
             type="file"
              name="listing[image]"   
             
              class="form-control"
            >

         <div class="invalid-feedback">Please enter a valid image URL (optional).</div>
    
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
                <label class="form-label">Price</label>
                <input 
                  type="number" 
                  name="listing[price]"   
                  value="<%= listing.price %>" 
                  class="form-control" 
                  required
                >
                <div class="invalid-feedback">Please enter a valid price.</div>
            </div>

            <div class="mb-3 col-md-8">
                <label class="form-label">Country</label>
                <input 
                  type="text" 
                  name="listing[country]"   
                  value="<%= listing.country %>" 
                  class="form-control" 
                  required
                >
                <div class="invalid-feedback">Please enter the country name.</div>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Location</label>
            <input 
              type="text" 
              name="listing[location]"   
              value="<%= listing.location %>" 
              class="form-control" 
              required
            >
            <div class="invalid-feedback">Please enter a valid location.</div>
        </div>

        <button type="submit" class="btn add-btn">Update Listing</button>

    </form>

  </div>
</div>