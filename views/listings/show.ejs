<% layout("layouts/boilerplate") %>


<script>
  const mapToken = "<%= mapToken %>";
const coordinates = <%- JSON.stringify(list.geometry.coordinates) %>;
</script>

<div class="row mt-3">
  <div class="col-8 offset-1">

    <div class="card col-6 offset-3 show-card listing-card">

      <h3><%= list.title %></h3>

      <img src="<%= list.image.url %>" 
           class="card-img-top show-img" 
           alt="listing_image">

      <div class="card-body">
        <p class="card-text">Owned by: <%= list.owner.username %></p>
        <p class="card-text"><%= list.description %></p>

        <p class="card-text">
          ₹ 
          <%= list.price ? list.price.toLocaleString("en-IN") : "N/A" %>
        </p>

        <p class="card-text"><%= list.location %></p>
        <p class="card-text"><%= list.country %></p>

      </div>

      <!-- Buttons autherization of edit and delete button  -->
      
   <% if(currUser && list.owner && list.owner.equals(currUser._id)){ %>

      <div class="row p-3">
        <div class="col-6">
          <a href="/listings/<%= list._id %>/edit" class="btn btn-dark w-100">
            Edit
          </a>
        </div>

        <div class="col-6">
          <form method="post" action="/listings/<%= list._id %>?_method=DELETE">
            <button class="btn btn-danger w-100">
              Delete
            </button>
          </form>
        </div>

      </div>
    <% } %>
     <!-- ---------------------------------- -->

    </div>

  </div>

</div>


<!-- ------------------------------------------Review ------------------ -->

<div class="col-8 offset-3 mb-3">
  
  <h4>Leave a Review</h4>
   
  <% if(currUser){ %>
<hr>
  <form action="/listings/<%= list._id %>/reviews" method="POST"  novalidate class=" mt-3 needs-validation">
    <!-- <div class="mb-3 mt-3">
      <label for="rating" class="form-label">Rating:</label>
       <input type="range" id="rating" name="review[rating]" min="1" max="5" class="form-range">
    </div> -->
    <!-- -------------- -->

    <div class="mb-3 mt-3">
  <label class="form-label">Rating:</label>

  <fieldset class="starability-slot">
     <input type="radio" id="no-rate" 
     class="input-no-rate" name="review[rating]"
      value="1" checked aria-label="No rating." />
     
    <input type="radio" id="first-rate1" name="review[rating]" value="1" required />
    <label for="first-rate1">1 star</label>
    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
    <label for="first-rate2">2 stars</label>
    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
    <label for="first-rate3">3 stars</label>
    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
    <label for="first-rate4">4 stars</label>
    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
    <label for="first-rate5">5 stars</label>

  </fieldset>
</div>
    <!-- ----- -->

    <div class="mb-3 mt-3">
      <label for="comments" class="form-label">Comments:</label>
      <textarea id="comments" id="comments" cols="30" rows="5" name="review[comments]" class="form-control" required></textarea>
     <div class="invalid-feedback">Please add some comments for the review.</div>
    </div>
    <button class="btn btn-outline-dark">Submit</button>
  </form>

<% } %>

<!-- -------show All reviews ------------------------->
<hr>
<% if (list.reviews.length>0){%>
<div class="row">
  <p><b>All Reviews</b></p>
<% for(let review of list.reviews){ %>
  <div class="card col-5 ms-3 mb-3">
    <div class="card-body">
       <h5 class="card-title">@<%= review.author.username %></h5>
           <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
       <p class="card-text"><%= review.comments %></p>
      <!-- rating -->
     
       <form class="mb-3" action="/listings/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
        <button class="btn btn-sm btn-dark">Delete</button>
       </form>
    </div>
  </div>
<% } %>
<% } %>
   

   
    </div>
<!-- googlem mapppp -->  
      <div class="col-8 offset-3 mb-3">
        <h3>Where you'll be</h3>
        <div id="map"></div>
      </div>
 

<!-- ----------- -->
    </div>
    

 <script src="/js/map.js"></script>
 
