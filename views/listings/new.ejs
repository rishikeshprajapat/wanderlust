<% layout('layouts/boilerplate') %>
<div class="row mt-3">
  <div class="col-8 offset-2">

    <h1>Create New Listing</h1>

    <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label" for="title">Title</label>
            <input type="text" name="listing[title]" placeholder="Title" class="form-control" required>
            <div class="invalid-feedback">Please provide a title for your listing.</div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="description">Description</label>
            <input type="text" name="listing[description]" placeholder="Description" class="form-control" required>
            <div class="invalid-feedback">Please enter a short description.</div>
        </div>

        <!-- <div class="mb-3">
            <label class="form-label">Image URL</label>
            <input type="text" name="listing[image]" placeholder="Image URL" class="form-control">
        </div> -->
        <!-- for use of cloud storage -->
        <div class="mb-3">
            <label class="form-label">Upload listing Image</label>
            <input type="file" name="listing[image]" class="form-control" required>
            
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
                <label class="form-label" for="price">Price</label>
                <input type="text" name="listing[price]" placeholder="Price" class="form-control" required>
                <div class="invalid-feedback">Please enter a valid price.</div>
            </div>

            <div class="mb-3 col-md-8">
                <label class="form-label" for="country">Country</label>
                <input type="text" name="listing[country]" placeholder="Country" class="form-control" required>
                <div class="invalid-feedback"> Please enter a Valid country. </div>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="location">Location</label>
            <input type="text" name="listing[location]" placeholder="Location" class="form-control" required>
            <div class="invalid-feedback"> Please enter a Valid location. </div>
        </div>

        <button type="submit" class="btn add-btn">Create New Listing</button>

    </form>

  </div>
</div>